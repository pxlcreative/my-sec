# Database
DATABASE_URL=postgresql://secadv:secadv@postgres:5432/secadv
POSTGRES_USER=secadv
POSTGRES_PASSWORD=secadv
POSTGRES_DB=secadv

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Application
SECRET_KEY=change-me-in-production
DATA_DIR=/data
LOG_LEVEL=INFO
# CORS: "*" allows all origins in dev; set to "https://yourdomain.com" in prod
CORS_ORIGINS=*

# SMTP alert delivery (Module G)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=changeme
